{
    "$schema": "https://mintlify.com/docs.json",
    "banner": {
        "content": "⚡ Get instant access to CeyPay. No waiting, no hassle. [Apply now](https://merchant.ceypay.io)",
        "dismissible": true
    },
    "theme": "aspen",
    "name": "CeyPay",
    "fonts": {
        "family": "Lato"
    },
    "colors": {
        "primary": "#1C6EF5",
        "light": "#5097FF",
        "dark": "#1C6EF5"
    },
    "topbarLinks": [
        {
            "name": "Dashboard",
            "url": "https://merchant.ceypay.io"
        }
    ],
    "topbarCtaButton": {
        "type": "github",
        "url": "https://github.com/CeyPay-io"
    },
    "favicon": "/favicon.ico",
    "logo": {
        "light": "/logo/CeyPayLongLight.svg",
        "dark": "/logo/CeyPayLongDark.svg"
    },
    "metadata": {
        "og:site_name": "CeyPay Documentation",
        "og:type": "website",
        "twitter:site": "@ceypayintern"
    },
    "feedback": {
        "suggestEdit": true,
        "raiseIssue": true,
        "thumbsRating": true
    },
    "search": {
        "prompt": "Search CeyPay docs..."
    },
    "modeToggle": {
        "default": "system"
    },
    "navigation": {
        "tabs": [
            {
                "tab": "Docs",
                "icon": "compass",
                "groups": [
                    {
                        "group": "Getting Started",
                        "pages": ["/introduction"]
                    },
                    {
                        "group": "Integrate",
                        "pages": [
                            "integrations/sandbox",
                            {
                                "group": "SDKs",
                                "pages": ["integrations/sdk/typescript"]
                            },
                            {
                                "group": "WordPress",
                                "pages": [
                                    "integrations/wordpress/introduction",
                                    "integrations/wordpress/quickstart",
                                    "integrations/wordpress/configuration",
                                    "integrations/wordpress/webhooks",
                                    "integrations/wordpress/testing",
                                    "integrations/wordpress/troubleshooting",
                                    "integrations/wordpress/privacy"
                                ]
                            }
                        ]
                    },
                    {
                        "group": "Resources",
                        "pages": ["guides/faq", "report-abuse"]
                    }
                ]
            },
            {
                "tab": "API Reference",
                "icon": "rectangle-terminal",
                "groups": [
                    {
                        "group": "Getting Started",
                        "pages": ["api/v1/quickstart", "api/v1/authentication"]
                    },
                    {
                        "group": "Guides",
                        "pages": [
                            "api/v1/direct-debit",
                            "api/v1/offramp",
                            "api/v1/payment-aggregator"
                        ]
                    },
                    {
                        "group": "Payments",
                        "openapi": "api/v1/openapi.json",
                        "pages": [
                            "POST /v1/payment",
                            "GET /v1/payment/list",
                            "GET /v1/payment/{id}"
                        ]
                    },
                    {
                        "group": "Payment Links",
                        "openapi": "api/v1/openapi.json",
                        "pages": [
                            "POST /v1/payment-link",
                            "GET /v1/payment-link/list",
                            "GET /v1/payment-link/{id}",
                            "DELETE /v1/payment-link/{id}"
                        ]
                    },
                    {
                        "group": "Direct Debit",
                        "openapi": "api/v1/openapi.json",
                        "pages": [
                            "GET /v1/direct-debit/scenario-code/list",
                            "POST /v1/direct-debit",
                            "GET /v1/direct-debit/list",
                            "GET /v1/direct-debit/{id}",
                            "POST /v1/direct-debit/{id}/sync",
                            "POST /v1/direct-debit/{id}/terminate",
                            "POST /v1/direct-debit/{id}/payment"
                        ]
                    },
                    {
                        "group": "Subscriptions",
                        "openapi": "api/v1/openapi.json",
                        "pages": [
                            "POST /v1/subscription",
                            "GET /v1/subscription/list",
                            "GET /v1/subscription/{id}",
                            "POST /v1/subscription/{id}/pause",
                            "POST /v1/subscription/{id}/resume",
                            "POST /v1/subscription/{id}/cancel",
                            "GET /v1/subscription/{id}/payments"
                        ]
                    },
                    {
                        "group": "Branches",
                        "openapi": "api/v1/openapi.json",
                        "pages": [
                            "POST /v1/branch",
                            "GET /v1/branch/list",
                            "GET /v1/branch/{id}",
                            "PATCH /v1/branch/{id}",
                            "DELETE /v1/branch/{id}"
                        ]
                    },
                    {
                        "group": "Withdrawals",
                        "openapi": "api/v1/openapi.json",
                        "pages": [
                            "POST /v1/withdrawal",
                            "GET /v1/withdrawal/list",
                            "GET /v1/withdrawal/{id}"
                        ]
                    },
                    {
                        "group": "Offramp",
                        "openapi": "api/v1/openapi.json",
                        "pages": [
                            "GET /v1/bank/list",
                            "POST /v1/aggregator/user",
                            "POST /v1/aggregator/user/{id}/bank-account",
                            "GET /v1/aggregator/user/{id}/bank-account/list",
                            "GET /v1/aggregator/quote",
                            "POST /v1/aggregator/offramp",
                            "GET /v1/aggregator/offramp/{id}",
                            "GET /v1/aggregator/report/ledger",
                            "GET /v1/aggregator/report/offramp"
                        ]
                    },
                    {
                        "group": "Reference",
                        "pages": ["api/v1/webhooks", "api/v1/errors", "api/v1/rate-limits"]
                    }
                ]
            },
            {
                "tab": "Changelog",
                "icon": "signal-stream",
                "pages": ["changelog/product-updates", "changelog/legal-updates"]
            },
            {
                "tab": "Support",
                "icon": "circle-question",
                "pages": ["support"]
            }
        ],
        "global": {
            "anchors": [
                {
                    "anchor": "Homepage",
                    "href": "https://ceypay.io",
                    "icon": "home"
                },
                {
                    "anchor": "GitHub",
                    "href": "https://github.com/CeyPay-io",
                    "icon": "github"
                },
                {
                    "anchor": "Status",
                    "href": "https://status.ceypay.io/",
                    "icon": "signal-alt"
                }
            ]
        }
    },
    "navbar": {
        "links": [
            {
                "label": "llms-full.txt",
                "href": "https://docs.ceypay.io/llms-full.txt"
            },
            {
                "label": "Support",
                "href": "mailto:support@ceypay.io"
            }
              ],
        "primary": {
            "type": "button",
            "label": "Dashboard",
            "href": "https://merchant.ceypay.io/"
        }
    },
    "tabs": [
        {
            "name": "API Reference",
            "url": "api/v1"
        }
    ],
    "api": {
        "url": "full",
        "playground": {
            "display": "interactive"
        }
    },
    "seo": {
        "indexHiddenPages": false,
        "metatags": {
            "canonical": "https://docs.ceypay.io",
            "og:image": "https://docs.ceypay.io/images/introduction_cover.png",
            "twitter:card": "summary_large_image",
            "twitter:site": "@ceypayintern",
            "robots": "index, follow",
            "language": "en",
            "author": "CeyPay"
        }
    },
    "analytics": {
        "plausible": {
            "domain": "docs.ceypay.io"
        }
    },
    "integrations": {
        "ga4": {
            "measurementId": "G-ZZVE717KCV"
        },
        "posthog": {
            "apiKey": "phc_fgL4iDNNh3YzNWKtBmQe0UOMz5ZExsWtCCpUndBXeos",
            "apiHost": "https://us.i.posthog.com"
        }
    },
    "contextual": {
        "options": ["copy", "view", "claude", "chatgpt", "cursor", "vscode"]
    },
    "redirects": [
        {
            "source": "/api/quickstart",
            "destination": "/api/v1/quickstart"
        },
        {
            "source": "/api/authentication",
            "destination": "/api/v1/authentication"
        },
        {
            "source": "/api/payments",
            "destination": "/api/v1/reference/create-payment"
        },
        {
            "source": "/api/payment-links",
            "destination": "/api/v1/reference/create-payment-link"
        },
        {
            "source": "/api/v1/payment-links-guide",
            "destination": "/api/v1/reference/create-payment-link"
        },
        {
            "source": "/api/v1/payments-guide",
            "destination": "/api/v1/reference/create-payment"
        },
        {
            "source": "/api/v1/payments",
            "destination": "/api/v1/reference/create-payment"
        },
        {
            "source": "/api/v1/payment-links",
            "destination": "/api/v1/reference/create-payment-link"
        },
        {
            "source": "/api/v1/branch",
            "destination": "/api/v1/reference/create-branch"
        },
        {
            "source": "/api/v1/withdrawal",
            "destination": "/api/v1/reference/create-withdrawal"
        },
        {
            "source": "/api/webhooks",
            "destination": "/api/v1/webhooks"
        },
        {
            "source": "/api/errors",
            "destination": "/api/v1/errors"
        },
        {
            "source": "/api/rate-limits",
            "destination": "/api/v1/rate-limits"
        },
        {
            "source": "/faq",
            "destination": "/guides/faq"
        },
        {
            "source": "/wordpress/:path*",
            "destination": "/integrations/wordpress/:path*"
        },
        {
            "source": "/guides/wordpress/:path*",
            "destination": "/integrations/wordpress/:path*"
        },
        {
            "source": "/changelog",
            "destination": "/changelog/product-updates"
        },
        {
            "source": "/api/v1/sandbox",
            "destination": "/integrations/sandbox"
        }
    ],
    "footer": {
        "socials": {
            "x-twitter": "https://x.com/ceypayintern",
            "telegram": "https://t.me/CeyPayio",
             "instagram": "https://www.instagram.com/ceypay.io",
            "github": "https://github.com/CeyPay-io",
             "facebook": "https://www.fb.com/ceypay.io/",
            "linkedin": "https://www.linkedin.com/showcase/ceypay/"
        },
        "links": [
            {
